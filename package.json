{
  "name": "mpa-db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep \"Authentication and navigation|MPA list and create workflow\"",
    "test:e2e:full": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.2",
    "@primevue/themes": "^4.5.2",
    "@tailwindcss/vite": "^4.1.16",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "axios": "^1.12.2",
    "esri-leaflet": "^3.0.9",
    "esri-leaflet-vector": "^3.0.3",
    "leaflet": "^1.9.4",
    "leaflet-auto-graticule": "^1.0.0",
    "leaflet-draw": "^1.0.4",
    "leaflet-easybutton": "^2.4.0",
    "leaflet-edgebuffer": "^1.0.1",
    "leaflet-search": "^3.0.7",
    "leaflet.markercluster": "^1.5.3",
    "mapbox-gl": "^3.17.0",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.2",
    "tailwindcss": "^4.1.16",
    "universal-cookie": "^8.0.1",
    "vee-validate": "^2.2.15",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@primevue/auto-import-resolver": "^4.5.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "~10.5.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "sass-embedded": "^1.93.3",
    "typescript": "~5.9.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.1.1"
  }
}
